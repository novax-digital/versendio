# =============================================================================
# Versendio — Umgebungsvariablen
# Kopie als .env.local anlegen und Werte eintragen. Kommentare je Variable.
# =============================================================================

# --- App ---------------------------------------------------------------------
# Anzeigename der Anwendung (UI, Mails)
APP_NAME="Versendio"
# Öffentliche Basis-URL (Produktion: https://versendio.de).
# IN PRODUKTION PFLICHT: Auth-Links und Stripe-Redirects werden daraus gebaut.
# Ohne sie brechen die Auth-Aktionen bewusst ab (Schutz vor Host-Header-Injection).
# Lokal darf sie leer bleiben (dann wird der Request-Origin verwendet).
APP_URL=https://app.versendio.de
# true = MockProvider aktiv, kein echter Briefversand (auch aktiv, wenn die
# E-Post-Konfiguration unvollständig ist)
MOCK_MODE=true
# true = Stripe-Kauf-UI & Checkout aktivieren (nur mit Testmodus-Keys!)
FEATURE_STRIPE=false
# Brief-PDFs werden n Tage nach finalem Versandstatus automatisch gelöscht
LETTER_RETENTION_DAYS=30

# --- Supabase ----------------------------------------------------------------
# Projekt-URL (Dashboard → Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://ycwoxycsiihzwwffqrte.supabase.co
# Öffentlicher anon-Key (RLS-geschützt, darf in den Client)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Inljd294eWNzaWloend3ZmZxcnRlIiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODM2NzQ2MjksImV4cCI6MjA5OTI1MDYyOX0.FF9CWtw492W198VhHccgLn7GIQ-j4cOKcQQZMX0FXjM
# Service-Role-Key — NUR serverseitig, umgeht RLS. Niemals in den Client!
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Inljd294eWNzaWloend3ZmZxcnRlIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImlhdCI6MTc4MzY3NDYyOSwiZXhwIjoyMDk5MjUwNjI5fQ.Mjfk6zOvfSbb50x_dlPp1oJH7dRAnXPTA5E7mV0D1TU
# Postgres-Connection-String für Migrationen (Dashboard → Settings → Database)
SUPABASE_DB_URL=postgresql://postgres:s7Z3VGeQghBolwlU@db.ycwoxycsiihzwwffqrte.supabase.co:5432/postgres

# --- E-POSTBUSINESS API (Deutsche Post / DocuGuide) ---------------------------
# Basis-URL der API (Produktions- oder Entwicklungsumgebung)
EPOST_BASE_URL=https://api.epost.docuguide.com
# vendorID aus dem API-Nutzervertrag
EPOST_VENDOR_ID=N3349506538H
# Zentraler Account (Eigenversender-Modell, ADR-0008): EKP = DP-Kundennummer
EPOST_EKP=5290173143
# API-Passwort (beim Erst-Setup über SMS-TAN gesetzt)
EPOST_PASSWORD=
# secret aus dem Erst-Setup (/api/Login/setPassword)
EPOST_SECRET=
# 32-Byte-Schlüssel (base64) zur AES-256-GCM-Verschlüsselung von Credentials
# und Token-Cache in der DB. Erzeugen: openssl rand -base64 32
EPOST_CREDENTIALS_KEY=NT6LdZsbQxNiaXKvzsg+jmm61ncw67qDIsQzpUA2Rjo=

# --- Stripe (nur Testmodus-Keys) ----------------------------------------------
# Secret Key (sk_test_…). Live-Keys (sk_live_…) werden vom Code abgelehnt —
# die Sperre muss zur Live-Schaltung bewusst entfernt werden (siehe
# docs/STRIPE_ACTIVATION.md).
STRIPE_SECRET_KEY=
# Webhook-Signing-Secret (whsec_…) für /api/webhooks/stripe.
# Ohne diese Variable antwortet der Webhook mit 503 (Gutschriften nur per Webhook).
STRIPE_WEBHOOK_SECRET=
# Publishable Key (pk_test_…). Derzeit NICHT verwendet: die Aufladung läuft über
# Stripe Hosted Checkout (Redirect), es wird kein Stripe.js im Client geladen.
# Nur nötig, falls später Elements/Payment-Element eingebunden werden.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# --- Mail ---------------------------------------------------------------------
# Resend-API-Key für transaktionale Mails; leer = Mails werden nur geloggt
RESEND_API_KEY=
# Absenderadresse, z. B. "Versendio <post@versendio.de>"
MAIL_FROM=info@versendio.de
# Optionaler SMTP-Fallback (smtp://user:pass@host:port) — statt Resend
SMTP_URL=

# --- Betrieb ------------------------------------------------------------------
# Diese E-Mail-Adresse wird durch `npm run seed:admin` zum ersten Admin
ADMIN_EMAIL=p.polley@novax-digital.de
# Secret für Cron-/Worker-Endpoints (/api/cron/*). Erzeugen: openssl rand -hex 32
# Ohne diese Variable antworten alle Worker mit 401 (fail closed).
# Vercel sendet sie automatisch als "Authorization: Bearer $CRON_SECRET".
CRON_SECRET=9f19fffc4ab537ad15a330f4ab641f0b5197efe091407f93fae999cd1986d0af
# Optional: Sentry-DSN für Error-Tracking
SENTRY_DSN=

# --- Nur für E2E-Tests ---------------------------------------------------------
# Basis-URL für Playwright (Default http://localhost:3000)
E2E_BASE_URL=
